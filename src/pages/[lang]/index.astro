---
// src/pages/[lang]/index.astro — Landing page with hero
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroForm from '../../components/HeroForm.astro';
import { t } from '../../i18n/utils';
import { loadCountries, loadAllOperators } from '../../lib/data-loader';
import { localePath } from '../../i18n/utils';
import type { Lang } from '../../lib/types';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
  ];
}

const lang = Astro.params.lang as Lang;
const countries = loadCountries();
const operators = loadAllOperators();

// Map country code to operator for links
const countryToOperator = new Map(operators.map(op => [op.operator.country, op.operator]));

const countryName = (code: string): string => {
  const country = countries.find((c) => c.code === code);
  if (!country) return code;
  return country[`name_${lang}` as keyof typeof country] as string;
};

const homeJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "PostCompare.eu",
  "url": "https://postcompare.eu",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web",
  "description": t(lang, 'site.description'),
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR",
  },
  "featureList": [
    "Compare postal rates across 32 European countries",
    "Letter and parcel price comparison",
    "Domestic and international shipping rates",
  ],
};
---

<BaseLayout
  title={t(lang, 'site.tagline')}
  description={t(lang, 'site.description')}
  lang={lang}
  jsonLd={homeJsonLd}
>
  {/* Hero section */}
  <section class="hero">
    <h1 class="hero__title">
      {lang === 'fr' ? <>Comparez les tarifs postaux<br />de <strong>32 pays européens</strong></> :
       lang === 'de' ? <>Vergleichen Sie Postgebühren<br />aus <strong>32 europäischen Ländern</strong></> :
       <>Compare postal rates<br />from <strong>32 European countries</strong></>}
    </h1>
    <p class="hero__subtitle">{t(lang, 'hero.subtitle')}</p>
    <HeroForm lang={lang} />
  </section>

  {/* How it works */}
  <section class="how-it-works" aria-label={t(lang, 'how.title')}>
    <h2 class="how-it-works__title">{t(lang, 'how.title')}</h2>
    <div class="how-it-works__grid">
      <div class="how-it-works__step">
        <div class="how-it-works__icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
            <path d="M8 28L20 8L32 28Z" stroke="currentColor" stroke-width="2" fill="none" stroke-linejoin="round"/>
            <line x1="20" y1="15" x2="20" y2="22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            <circle cx="20" cy="25.5" r="1.2" fill="currentColor"/>
          </svg>
        </div>
        <span class="how-it-works__number">1</span>
        <h3>{t(lang, 'how.step1_title')}</h3>
        <p>{t(lang, 'how.step1_text')}</p>
      </div>
      <div class="how-it-works__step">
        <div class="how-it-works__icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
            <rect x="4" y="10" width="14" height="10" rx="2" stroke="currentColor" stroke-width="2" fill="none"/>
            <path d="M4 10L11 17L18 10" stroke="currentColor" stroke-width="2"/>
            <rect x="22" y="10" width="14" height="10" rx="2" stroke="currentColor" stroke-width="2" fill="none"/>
            <path d="M22 10L29 17L36 10" stroke="currentColor" stroke-width="2"/>
            <line x1="11" y1="26" x2="11" y2="30" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <line x1="29" y1="24" x2="29" y2="30" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <line x1="6" y1="30" x2="16" y2="30" stroke="currentColor" stroke-width="1.5"/>
            <line x1="24" y1="30" x2="34" y2="30" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <span class="how-it-works__number">2</span>
        <h3>{t(lang, 'how.step2_title')}</h3>
        <p>{t(lang, 'how.step2_text')}</p>
      </div>
      <div class="how-it-works__step">
        <div class="how-it-works__icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="18" r="12" stroke="currentColor" stroke-width="2" fill="none"/>
            <circle cx="20" cy="18" r="5" stroke="currentColor" stroke-width="2" fill="none"/>
            <circle cx="20" cy="18" r="1.5" fill="currentColor"/>
            <line x1="20" y1="6" x2="20" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <line x1="20" y1="33" x2="20" y2="30" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <line x1="8" y1="18" x2="5" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <line x1="35" y1="18" x2="32" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <span class="how-it-works__number">3</span>
        <h3>{t(lang, 'how.step3_title')}</h3>
        <p>{t(lang, 'how.step3_text')}</p>
      </div>
    </div>
  </section>

  {/* Countries covered */}
  <section class="countries-section" aria-label={t(lang, 'countries_section.title')}>
    <h2 class="countries-section__title">{t(lang, 'countries_section.title')}</h2>
    <p class="countries-section__subtitle">
      {lang === 'fr' ? 'Cliquez sur un pays pour voir les tarifs détaillés de sa poste nationale.' :
       lang === 'de' ? 'Klicken Sie auf ein Land, um die detaillierten Tarife seines Postdienstes zu sehen.' :
       'Click on a country to see the detailed rates of its national postal service.'}
    </p>
    <div class="countries-grid">
      {countries.map((c) => {
        const op = countryToOperator.get(c.code);
        return op ? (
          <a href={localePath(lang, `/operator/${op.id}`)} class="countries-grid__item countries-grid__item--link">
            <span class="countries-grid__flag">{c.flag}</span>
            <span class="countries-grid__info">
              <span class="countries-grid__name">{countryName(c.code)}</span>
              <span class="countries-grid__operator">{op.name}</span>
            </span>
          </a>
        ) : (
          <div class="countries-grid__item">
            <span class="countries-grid__flag">{c.flag}</span>
            <span class="countries-grid__info">
              <span class="countries-grid__name">{countryName(c.code)}</span>
            </span>
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>
