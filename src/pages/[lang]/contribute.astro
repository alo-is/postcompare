---
// src/pages/[lang]/contribute.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';
import type { Lang } from '../../lib/types';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
  ];
}

const lang = Astro.params.lang as Lang;
---

<BaseLayout title={t(lang, 'contribute.title')} lang={lang}>
  <div class="content-page">
    <h1>{t(lang, 'contribute.title')}</h1>

    <p>{t(lang, 'contribute.intro')}</p>

    <h2>{t(lang, 'contribute.report_title')}</h2>
    <p>{t(lang, 'contribute.report_text')}</p>
    <p>
      <a href="https://github.com/alo-is/postcompare/issues/new?template=price-update.yml" target="_blank" rel="noopener" class="contribute-link">
        {lang === 'fr' ? 'Ouvrir une Issue' : lang === 'de' ? 'Issue erstellen' : 'Open an Issue'} &rarr;
      </a>
    </p>

    <h2>{t(lang, 'contribute.fix_title')}</h2>
    <p>{t(lang, 'contribute.fix_text')}</p>

    <h2>{t(lang, 'contribute.steps_title')}</h2>
    <ol>
      <li>{t(lang, 'contribute.step1')} &mdash; <a href="https://github.com/alo-is/postcompare/fork" target="_blank" rel="noopener">github.com/alo-is/postcompare</a></li>
      <li>{t(lang, 'contribute.step2')}</li>
      <li>{t(lang, 'contribute.step3')} &mdash; <code>npm run validate</code></li>
      <li>{t(lang, 'contribute.step4')}</li>
    </ol>
  </div>
</BaseLayout>
