---
// src/pages/[lang]/rankings.astro — Composite rankings of European postal services
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, localePath } from '../../i18n/utils';
import { loadCountries, loadAllOperators, loadPriceLevelIndices } from '../../lib/data-loader';
import { compare } from '../../lib/comparison-engine';
import type { Lang, ComparisonResult } from '../../lib/types';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
  ];
}

const lang = Astro.params.lang as Lang;
const countries = loadCountries();
const operators = loadAllOperators();
const pliData = loadPriceLevelIndices();
const pli = pliData.indices;

// --- Helpers ---
const countryName = (code: string): string => {
  const c = countries.find((c) => c.code === code);
  if (!c) return code;
  return c[`name_${lang}` as keyof typeof c] as string;
};
const countryFlag = (code: string): string =>
  countries.find((c) => c.code === code)?.flag ?? '';

// --- Composite letter ranking (20g, 50g, 100g, 200g) ---
const letterWeights = [20, 50, 100, 200];
const letterRanksByWeight: Map<string, number[]> = new Map();
const letterPricesByWeight: Map<string, number[]> = new Map();

for (const w of letterWeights) {
  const results = compare(operators, { type: 'letter', weight: w, origin: 'all', destination: 'domestic' });
  results.forEach((r, i) => {
    const cc = r.operator.country;
    if (!letterRanksByWeight.has(cc)) letterRanksByWeight.set(cc, []);
    if (!letterPricesByWeight.has(cc)) letterPricesByWeight.set(cc, []);
    letterRanksByWeight.get(cc)!.push(i + 1);
    letterPricesByWeight.get(cc)!.push(r.priceEur);
  });
}

// Build composite: average rank + average price
type CompositeEntry = {
  country: string;
  operatorName: string;
  operatorId: string;
  avgRank: number;
  avgPrice: number;
  avgPricePPP: number; // PPP-adjusted average price
  prices: { weight: number; price: number }[];
  tierCount: number;
};

function buildComposite(
  ranksByWeight: Map<string, number[]>,
  pricesByWeight: Map<string, number[]>,
  weights: number[],
): CompositeEntry[] {
  const entries: CompositeEntry[] = [];
  for (const [cc, ranks] of ranksByWeight) {
    const prices = pricesByWeight.get(cc) ?? [];
    const op = operators.find(o => o.operator.country === cc);
    if (!op) continue;
    const avgRank = ranks.reduce((s, r) => s + r, 0) / ranks.length;
    const avgPrice = prices.reduce((s, p) => s + p, 0) / prices.length;
    const countryPLI = pli[cc] ?? 100;
    const avgPricePPP = avgPrice / (countryPLI / 100);
    const priceDetails = weights.map((w, i) => ({ weight: w, price: prices[i] ?? 0 })).filter(p => p.price > 0);
    entries.push({
      country: cc,
      operatorName: op.operator.name,
      operatorId: op.operator.id,
      avgRank,
      avgPrice,
      avgPricePPP,
      prices: priceDetails,
      tierCount: ranks.length,
    });
  }
  return entries.sort((a, b) => a.avgRank - b.avgRank);
}

const letterRanking = buildComposite(letterRanksByWeight, letterPricesByWeight, letterWeights);

// --- Composite parcel ranking (1kg, 2kg, 5kg, 10kg) ---
const parcelWeights = [1, 2, 5, 10];
const parcelRanksByWeight: Map<string, number[]> = new Map();
const parcelPricesByWeight: Map<string, number[]> = new Map();

for (const w of parcelWeights) {
  const results = compare(operators, { type: 'parcel', weight: w, origin: 'all', destination: 'domestic' });
  results.forEach((r, i) => {
    const cc = r.operator.country;
    if (!parcelRanksByWeight.has(cc)) parcelRanksByWeight.set(cc, []);
    if (!parcelPricesByWeight.has(cc)) parcelPricesByWeight.set(cc, []);
    parcelRanksByWeight.get(cc)!.push(i + 1);
    parcelPricesByWeight.get(cc)!.push(r.priceEur);
  });
}

const parcelRanking = buildComposite(parcelRanksByWeight, parcelPricesByWeight, parcelWeights);

// --- Stats ---
function avgOf(entries: CompositeEntry[]): number {
  return entries.reduce((s, e) => s + e.avgPrice, 0) / entries.length;
}
function medianOf(entries: CompositeEntry[]): number {
  const sorted = [...entries].sort((a, b) => a.avgPrice - b.avgPrice);
  const mid = Math.floor(sorted.length / 2);
  return sorted.length % 2 !== 0 ? sorted[mid].avgPrice : (sorted[mid - 1].avgPrice + sorted[mid].avgPrice) / 2;
}

// --- Medal ---
function medal(rank: number): string {
  if (rank === 1) return '\u{1F947}';
  if (rank === 2) return '\u{1F948}';
  if (rank === 3) return '\u{1F949}';
  return '';
}
function rowClass(rank: number, total: number): string {
  if (rank <= 5) return 'rk-row--cheap';
  if (rank > total - 5) return 'rk-row--expensive';
  return '';
}

// --- i18n labels ---
const letterWeightLabels = letterWeights.map(w => `${w}g`);
const parcelWeightLabels = parcelWeights.map(w => `${w}kg`);

const rankingsJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": t(lang, 'rankings.title'),
  "description": t(lang, 'rankings.subtitle'),
  "url": `https://www.postcompare.eu/${lang}/rankings`,
};
---

<BaseLayout
  title={t(lang, 'rankings.title')}
  description={t(lang, 'rankings.subtitle')}
  lang={lang}
  jsonLd={rankingsJsonLd}
>
  <section class="rk-hero">
    <h1 class="rk-hero__title">{t(lang, 'rankings.title')}</h1>
    <p class="rk-hero__subtitle">{t(lang, 'rankings.subtitle')}</p>
  </section>

  <div class="rk-page">
    <p class="rk-methodology">
      {lang === 'fr' ? 'Classement basé sur la moyenne des rangs pour les poids : ' :
       lang === 'de' ? 'Rangliste basierend auf dem Durchschnittsrang für Gewichte: ' :
       'Ranking based on average rank across weights: '}
      <strong>
        {lang === 'fr' ? `Lettres : ${letterWeightLabels.join(', ')} — Colis : ${parcelWeightLabels.join(', ')}` :
         lang === 'de' ? `Briefe: ${letterWeightLabels.join(', ')} — Pakete: ${parcelWeightLabels.join(', ')}` :
         `Letters: ${letterWeightLabels.join(', ')} — Parcels: ${parcelWeightLabels.join(', ')}`}
      </strong>
    </p>

    {/* ====== Letters composite ranking ====== */}
    <section class="rk-section" aria-label={t(lang, 'rankings.letters_title')}>
      <div class="rk-section__header">
        <div class="rk-section__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 4l10 8 10-8"/>
          </svg>
        </div>
        <h2 class="rk-section__title">{t(lang, 'rankings.letters_title')}</h2>
      </div>

      <div class="rk-table-wrap">
        <table class="rk-table">
          <thead>
            <tr>
              <th class="rk-th--rank">#</th>
              <th>{t(lang, 'rankings.country')}</th>
              <th>{t(lang, 'rankings.operator')}</th>
              {letterWeightLabels.map(w => <th class="rk-th--price">{w}</th>)}
              <th class="rk-th--price">{lang === 'fr' ? 'Moy.' : lang === 'de' ? 'Ø' : 'Avg.'}</th>
              <th class="rk-th--price rk-th--ppp">{lang === 'fr' ? 'PPA*' : lang === 'de' ? 'KKP*' : 'PPP*'}</th>
            </tr>
          </thead>
          <tbody>
            {letterRanking.map((e, i) => {
              const rank = i + 1;
              return (
                <tr class={`rk-row ${rowClass(rank, letterRanking.length)}`} data-country={e.country}>
                  <td class="rk-td--rank"><span class="rk-rank">{medal(rank)} {rank}</span></td>
                  <td class="rk-td--country">
                    <span class="rk-flag">{countryFlag(e.country)}</span>
                    <span class="rk-country-name">{countryName(e.country)}</span>
                  </td>
                  <td class="rk-td--operator">
                    <a href={localePath(lang, `/operator/${e.operatorId}`)}>{e.operatorName}</a>
                  </td>
                  {e.prices.map(p => (
                    <td class="rk-td--price"><span class="rk-price-sm">{p.price.toFixed(2)}&euro;</span></td>
                  ))}
                  {/* Fill missing tiers */}
                  {Array.from({ length: letterWeights.length - e.prices.length }).map(() => (
                    <td class="rk-td--price"><span class="rk-price-na">—</span></td>
                  ))}
                  <td class="rk-td--price"><span class="rk-price">{e.avgPrice.toFixed(2)}&nbsp;&euro;</span></td>
                  <td class="rk-td--price rk-td--ppp"><span class="rk-price-ppp">{e.avgPricePPP.toFixed(2)}&nbsp;&euro;</span></td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      <div class="rk-stats">
        <div class="rk-stat">
          <span class="rk-stat__label">{t(lang, 'rankings.median')}</span>
          <span class="rk-stat__value">{medianOf(letterRanking).toFixed(2)}&nbsp;&euro;</span>
        </div>
        <div class="rk-stat">
          <span class="rk-stat__label">{t(lang, 'rankings.average')}</span>
          <span class="rk-stat__value">{avgOf(letterRanking).toFixed(2)}&nbsp;&euro;</span>
        </div>
      </div>

      <div class="rk-legend">
        <span class="rk-legend__item rk-legend__item--cheap">{t(lang, 'rankings.cheapest')}</span>
        <span class="rk-legend__item rk-legend__item--expensive">{t(lang, 'rankings.most_expensive')}</span>
      </div>
    </section>

    <div class="rk-airmail-sep" aria-hidden="true"></div>

    {/* ====== Parcels composite ranking ====== */}
    <section class="rk-section" aria-label={t(lang, 'rankings.parcels_title')}>
      <div class="rk-section__header">
        <div class="rk-section__icon rk-section__icon--parcel">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </div>
        <h2 class="rk-section__title">{t(lang, 'rankings.parcels_title')}</h2>
      </div>

      <div class="rk-table-wrap">
        <table class="rk-table">
          <thead>
            <tr>
              <th class="rk-th--rank">#</th>
              <th>{t(lang, 'rankings.country')}</th>
              <th>{t(lang, 'rankings.operator')}</th>
              {parcelWeightLabels.map(w => <th class="rk-th--price">{w}</th>)}
              <th class="rk-th--price">{lang === 'fr' ? 'Moy.' : lang === 'de' ? 'Ø' : 'Avg.'}</th>
              <th class="rk-th--price rk-th--ppp">{lang === 'fr' ? 'PPA*' : lang === 'de' ? 'KKP*' : 'PPP*'}</th>
            </tr>
          </thead>
          <tbody>
            {parcelRanking.map((e, i) => {
              const rank = i + 1;
              return (
                <tr class={`rk-row ${rowClass(rank, parcelRanking.length)}`} data-country={e.country}>
                  <td class="rk-td--rank"><span class="rk-rank">{medal(rank)} {rank}</span></td>
                  <td class="rk-td--country">
                    <span class="rk-flag">{countryFlag(e.country)}</span>
                    <span class="rk-country-name">{countryName(e.country)}</span>
                  </td>
                  <td class="rk-td--operator">
                    <a href={localePath(lang, `/operator/${e.operatorId}`)}>{e.operatorName}</a>
                  </td>
                  {e.prices.map(p => (
                    <td class="rk-td--price"><span class="rk-price-sm">{p.price.toFixed(2)}&euro;</span></td>
                  ))}
                  {Array.from({ length: parcelWeights.length - e.prices.length }).map(() => (
                    <td class="rk-td--price"><span class="rk-price-na">—</span></td>
                  ))}
                  <td class="rk-td--price"><span class="rk-price">{e.avgPrice.toFixed(2)}&nbsp;&euro;</span></td>
                  <td class="rk-td--price rk-td--ppp"><span class="rk-price-ppp">{e.avgPricePPP.toFixed(2)}&nbsp;&euro;</span></td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      <div class="rk-stats">
        <div class="rk-stat">
          <span class="rk-stat__label">{t(lang, 'rankings.median')}</span>
          <span class="rk-stat__value">{medianOf(parcelRanking).toFixed(2)}&nbsp;&euro;</span>
        </div>
        <div class="rk-stat">
          <span class="rk-stat__label">{t(lang, 'rankings.average')}</span>
          <span class="rk-stat__value">{avgOf(parcelRanking).toFixed(2)}&nbsp;&euro;</span>
        </div>
      </div>

      <div class="rk-legend">
        <span class="rk-legend__item rk-legend__item--cheap">{t(lang, 'rankings.cheapest')}</span>
        <span class="rk-legend__item rk-legend__item--expensive">{t(lang, 'rankings.most_expensive')}</span>
      </div>
    </section>

    <div class="rk-cta">
      <a href={localePath(lang, '/compare')} class="op-cta__btn">
        {t(lang, 'rankings.cta')} &rarr;
      </a>
    </div>

    <footer class="rk-footnote">
      <p>
        {lang === 'fr' ? '* PPA (Parité de Pouvoir d\'Achat) : prix ajusté au coût de la vie de chaque pays. Un timbre à 1€ en Bulgarie (coût de la vie bas) pèse plus dans le budget qu\'un timbre à 1€ en Suisse.' :
         lang === 'de' ? '* KKP (Kaufkraftparität): Preis angepasst an die Lebenshaltungskosten jedes Landes. Eine Briefmarke für 1€ in Bulgarien (niedrige Lebenshaltungskosten) belastet das Budget stärker als eine 1€-Briefmarke in der Schweiz.' :
         '* PPP (Purchasing Power Parity): price adjusted for each country\'s cost of living. A €1 stamp in Bulgaria (low cost of living) weighs more on the budget than a €1 stamp in Switzerland.'}
      </p>
      <p class="rk-footnote__source">
        {lang === 'fr' ? 'Source : ' : lang === 'de' ? 'Quelle: ' : 'Source: '}
        <a href={pliData.source_url} target="_blank" rel="noopener">{pliData.source}</a>
        {` (${pliData.year})`}
      </p>
    </footer>
  </div>
</BaseLayout>

<script>
  // Highlight user's country
  (function() {
    const lang = (navigator.language || '').split('-');
    let code = '';
    if (lang.length >= 2) code = lang[1].toUpperCase();
    else {
      const map: Record<string, string> = {fr:'FR',de:'DE',es:'ES',it:'IT',nl:'NL',pt:'PT',pl:'PL',ro:'RO',hu:'HU',el:'GR',bg:'BG',hr:'HR',sk:'SK',sl:'SI',lt:'LT',lv:'LV',et:'EE',fi:'FI',sv:'SE',da:'DK',no:'NO',is:'IS',en:'GB'};
      code = map[lang[0].toLowerCase()] || '';
    }
    if (!code) return;
    document.querySelectorAll(`tr[data-country="${code}"]`).forEach(row => {
      row.classList.add('rk-row--user');
    });
  })();
</script>
