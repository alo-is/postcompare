---
// src/components/LanguagePicker.astro
import { languages, languageNames } from '../i18n/utils';
import type { Lang } from '../lib/types';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
---

<div class="lang-picker">
  {
    languages.map((l) => (
      <a
        href={`/${l}${currentPath || '/'}`}
        class:list={['lang-picker__link', { 'lang-picker__link--active': l === lang }]}
      >
        {languageNames[l]}
      </a>
    ))
  }
</div>
