---
// src/components/HeroForm.astro
import { t, localePath } from '../i18n/utils';
import { loadCountries } from '../lib/data-loader';
import type { Lang, Country } from '../lib/types';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const countries = loadCountries();

const countryName = (c: Country): string => {
  return c[`name_${lang}` as keyof Country] as string;
};

const supportedCodes = countries.map((c) => c.code);
---

<form class="wizard" action={localePath(lang, '/compare')} method="get">
  <div class="wizard__steps">
    <div class="wizard__step">
      <span class="wizard__step-number">1</span>
      <div class="wizard__step-content">
        <label class="wizard__label" for="hero-type">{t(lang, 'form.type')}</label>
        <div class="wizard__type-toggle">
          <label class="wizard__type-option wizard__type-option--active" id="opt-letter">
            <input type="radio" name="type" value="letter" checked class="wizard__radio" />
            <svg width="20" height="16" viewBox="0 0 20 16" fill="none" aria-hidden="true">
              <rect x="1" y="1" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M1 1L10 9L19 1" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            {t(lang, 'form.letter')}
          </label>
          <label class="wizard__type-option" id="opt-parcel">
            <input type="radio" name="type" value="parcel" class="wizard__radio" />
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <rect x="1" y="4" width="16" height="13" rx="1.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M1 4L9 1L17 4" stroke="currentColor" stroke-width="1.5"/>
              <line x1="9" y1="1" x2="9" y2="17" stroke="currentColor" stroke-width="1" opacity="0.4"/>
            </svg>
            {t(lang, 'form.parcel')}
          </label>
        </div>
      </div>
    </div>

    <div class="wizard__step">
      <span class="wizard__step-number">2</span>
      <div class="wizard__step-content">
        <label class="wizard__label" for="hero-weight" id="hero-weight-label">
          {t(lang, 'form.weight')}
        </label>
        <div class="wizard__weight-row">
          <input
            id="hero-weight"
            name="weight"
            type="number"
            class="wizard__input"
            value="20"
            min="1"
            max="2000"
            step="1"
          />
          <span class="wizard__unit" id="hero-weight-unit">g</span>
        </div>
      </div>
    </div>

    <div class="wizard__step">
      <span class="wizard__step-number">3</span>
      <div class="wizard__step-content">
        <label class="wizard__label" for="hero-origin">{t(lang, 'form.origin')}</label>
        <select id="hero-origin" name="origin" class="wizard__select">
          <option value="all">{t(lang, 'form.all_countries')}</option>
          {countries.map((c) => (
            <option value={c.code}>{c.flag} {countryName(c)}</option>
          ))}
        </select>
      </div>
    </div>

    <div class="wizard__step">
      <span class="wizard__step-number">4</span>
      <div class="wizard__step-content">
        <label class="wizard__label" for="hero-destination">{t(lang, 'form.destination')}</label>
        <select id="hero-destination" name="destination" class="wizard__select">
          <option value="domestic">{t(lang, 'form.domestic')}</option>
          {countries.map((c) => (
            <option value={c.code}>{c.flag} {countryName(c)}</option>
          ))}
        </select>
      </div>
    </div>
  </div>

  <button type="submit" class="wizard__submit">
    {t(lang, 'hero.cta')}
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="margin-left: 8px;">
      <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</form>

<script define:vars={{ supportedCodes }}>
  // Auto-detect user's country
  (function() {
    const originSelect = document.getElementById('hero-origin');
    if (!originSelect || originSelect.value !== 'all') return;
    const lang = navigator.language || '';
    const parts = lang.split('-');
    let code = '';
    if (parts.length >= 2) {
      code = parts[1].toUpperCase();
    } else {
      const map = { 'fr':'FR','de':'DE','es':'ES','it':'IT','nl':'NL','pt':'PT','pl':'PL','ro':'RO','hu':'HU','el':'GR','bg':'BG','hr':'HR','sk':'SK','sl':'SI','lt':'LT','lv':'LV','et':'EE','fi':'FI','sv':'SE','da':'DK','no':'NO','is':'IS','en':'GB' };
      code = map[parts[0].toLowerCase()] || '';
    }
    if (code && supportedCodes.includes(code)) originSelect.value = code;
  })();

  // Type toggle behavior
  (function() {
    const radios = document.querySelectorAll('.wizard__radio');
    const weightInput = document.getElementById('hero-weight');
    const weightUnit = document.getElementById('hero-weight-unit');
    const optLetter = document.getElementById('opt-letter');
    const optParcel = document.getElementById('opt-parcel');

    radios.forEach(r => r.addEventListener('change', function() {
      if (this.value === 'parcel') {
        weightInput.value = '0.5'; weightInput.min = '0.1'; weightInput.max = '50'; weightInput.step = '0.1';
        weightUnit.textContent = 'kg';
        optParcel.classList.add('wizard__type-option--active');
        optLetter.classList.remove('wizard__type-option--active');
      } else {
        weightInput.value = '20'; weightInput.min = '1'; weightInput.max = '2000'; weightInput.step = '1';
        weightUnit.textContent = 'g';
        optLetter.classList.add('wizard__type-option--active');
        optParcel.classList.remove('wizard__type-option--active');
      }
    }));
  })();
</script>
