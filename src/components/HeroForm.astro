---
// src/components/HeroForm.astro
import { t, localePath } from '../i18n/utils';
import { loadCountries } from '../lib/data-loader';
import type { Lang, Country } from '../lib/types';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const countries = loadCountries();

const countryName = (c: Country): string => {
  return c[`name_${lang}` as keyof Country] as string;
};

const supportedCodes = countries.map((c) => c.code);
---

<form class="ship-label" action={localePath(lang, '/compare')} method="get">
  <div class="ship-label__header">
    <svg width="18" height="14" viewBox="0 0 20 16" fill="none" aria-hidden="true">
      <rect x="1" y="1" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
      <path d="M1 1L10 9L19 1" stroke="currentColor" stroke-width="1.5"/>
    </svg>
    <span>{lang === 'fr' ? 'Votre envoi' : lang === 'de' ? 'Ihre Sendung' : 'Your shipment'}</span>
  </div>

  <div class="ship-label__body">
    <div class="ship-label__row">
      <div class="ship-label__field">
        <label class="ship-label__lbl">{t(lang, 'form.type')}</label>
        <div class="ship-label__toggle">
          <label class="ship-label__opt ship-label__opt--active" id="opt-letter">
            <input type="radio" name="type" value="letter" checked class="sr-only" />
            <svg width="16" height="13" viewBox="0 0 20 16" fill="none" aria-hidden="true">
              <rect x="1" y="1" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M1 1L10 9L19 1" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            {t(lang, 'form.letter')}
          </label>
          <label class="ship-label__opt" id="opt-parcel">
            <input type="radio" name="type" value="parcel" class="sr-only" />
            <svg width="15" height="15" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <rect x="1" y="4" width="16" height="13" rx="1.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M1 4L9 1L17 4" stroke="currentColor" stroke-width="1.5"/>
              <line x1="9" y1="1" x2="9" y2="17" stroke="currentColor" stroke-width="1" opacity="0.3"/>
            </svg>
            {t(lang, 'form.parcel')}
          </label>
        </div>
      </div>
      <div class="ship-label__field ship-label__field--weight">
        <label class="ship-label__lbl" for="hero-weight">{t(lang, 'form.weight')}</label>
        <div class="ship-label__weight">
          <input id="hero-weight" name="weight" type="number" class="ship-label__input" value="20" min="1" max="2000" step="1" />
          <span class="ship-label__unit" id="hero-weight-unit">g</span>
        </div>
      </div>
    </div>

    <div class="ship-label__divider"></div>

    <div class="ship-label__row">
      <div class="ship-label__field">
        <label class="ship-label__lbl" for="hero-origin">{t(lang, 'form.origin')}</label>
        <select id="hero-origin" name="origin" class="ship-label__select">
          <option value="all">{t(lang, 'form.all_countries')}</option>
          {countries.map((c) => (
            <option value={c.code}>{c.flag} {countryName(c)}</option>
          ))}
        </select>
        <span class="ship-label__hint" id="origin-hint"></span>
      </div>
      <div class="ship-label__field ship-label__field--arrow">
        <span class="ship-label__arrow" aria-hidden="true">&rarr;</span>
      </div>
      <div class="ship-label__field">
        <label class="ship-label__lbl" for="hero-destination">{t(lang, 'form.destination')}</label>
        <select id="hero-destination" name="destination" class="ship-label__select">
          <option value="domestic">{t(lang, 'form.domestic')}</option>
          {countries.map((c) => (
            <option value={c.code}>{c.flag} {countryName(c)}</option>
          ))}
        </select>
      </div>
    </div>
  </div>

  <button type="submit" class="ship-label__submit">
    {t(lang, 'hero.cta')}
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</form>

<script define:vars={{ supportedCodes }}>
  // Detect user's country and show as clickable hint
  (function() {
    const originSelect = document.getElementById('hero-origin');
    const hint = document.getElementById('origin-hint');
    if (!originSelect || !hint) return;
    const lang = navigator.language || '';
    const parts = lang.split('-');
    let code = '';
    if (parts.length >= 2) {
      code = parts[1].toUpperCase();
    } else {
      const map = { 'fr':'FR','de':'DE','es':'ES','it':'IT','nl':'NL','pt':'PT','pl':'PL','ro':'RO','hu':'HU','el':'GR','bg':'BG','hr':'HR','sk':'SK','sl':'SI','lt':'LT','lv':'LV','et':'EE','fi':'FI','sv':'SE','da':'DK','no':'NO','is':'IS','en':'GB' };
      code = map[parts[0].toLowerCase()] || '';
    }
    if (code && supportedCodes.includes(code)) {
      const opt = originSelect.querySelector('option[value="' + code + '"]');
      if (opt) {
        hint.textContent = opt.textContent.trim() + ' ?';
        hint.style.cursor = 'pointer';
        hint.addEventListener('click', function() {
          originSelect.value = code;
          hint.style.display = 'none';
        });
      }
    }
  })();

  // Type toggle
  (function() {
    const radios = document.querySelectorAll('.sr-only');
    const weightInput = document.getElementById('hero-weight');
    const weightUnit = document.getElementById('hero-weight-unit');
    const optLetter = document.getElementById('opt-letter');
    const optParcel = document.getElementById('opt-parcel');
    if (!weightInput || !weightUnit || !optLetter || !optParcel) return;

    radios.forEach(r => r.addEventListener('change', function() {
      if (this.value === 'parcel') {
        weightInput.value = '0.5'; weightInput.min = '0.1'; weightInput.max = '50'; weightInput.step = '0.1';
        weightUnit.textContent = 'kg';
        optParcel.classList.add('ship-label__opt--active');
        optLetter.classList.remove('ship-label__opt--active');
      } else {
        weightInput.value = '20'; weightInput.min = '1'; weightInput.max = '2000'; weightInput.step = '1';
        weightUnit.textContent = 'g';
        optLetter.classList.add('ship-label__opt--active');
        optParcel.classList.remove('ship-label__opt--active');
      }
    }));
  })();
</script>
