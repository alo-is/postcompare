---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { languages } from '../i18n/utils';
import type { Lang } from '../lib/types';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  jsonLd?: Record<string, unknown>;
}

const { title, description, lang, jsonLd } = Astro.props;

const fullTitle = `${title} | PostCompare.eu`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const localeMap: Record<Lang, string> = {
  fr: 'fr_FR',
  en: 'en_GB',
  de: 'de_DE',
};

// Build hreflang paths by swapping the lang prefix
const currentPathWithoutLang = Astro.url.pathname.replace(/^\/(fr|en|de)/, '');

// WebSite JSON-LD (always present)
const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "PostCompare.eu",
  "url": "https://postcompare.eu",
  "description": "European postal service price comparator",
  "inLanguage": [
    "fr",
    "en",
    "de"
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />

    {/* Canonical URL */}
    <link rel="canonical" href={canonicalURL.href} />

    {/* Hreflang alternate links */}
    {languages.map((l) => (
      <link rel="alternate" hreflang={l} href={`https://postcompare.eu/${l}${currentPathWithoutLang}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`https://postcompare.eu/fr${currentPathWithoutLang}`} />

    {/* Open Graph */}
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={localeMap[lang]} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="PostCompare.eu" />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* JSON-LD: WebSite schema */}
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />

    {/* Page-specific JSON-LD */}
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
